generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STUDENT
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments Enrollment[]

  @@map("users")
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String?
  thumbnail   String?
  price       Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  weeks       Week[]
  enrollments Enrollment[]

  @@map("courses")
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  enrolledAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId]) // ek studentkta ek course ekak 2 paratha enroll wenna denne na
  @@map("enrollments")
}

model Week {
  id         String   @id @default(cuid())
  courseId   String
  weekNumber Int
  title      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  assignments Assignment[]
  quizzes     Quiz[]
  recordings  Recording[]

  @@unique([courseId, weekNumber]) // ek course ekkata ek week number ekak witharai
  @@map("weeks")
}

model Assignment {
  id          String    @id @default(cuid())
  weekId      String
  title       String
  description String?
  fileUrl     String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  week Week @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@map("assignments")
}

model Quiz {
  id        String   @id @default(cuid())
  weekId    String
  title     String
  fileUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  week Week @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@map("quizzes")
}

model Recording {
  id        String   @id @default(cuid())
  weekId    String
  title     String
  videoUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  week Week @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@map("recordings")
}